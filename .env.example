# ─── Backend ───────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:3000/api/v1

# ─── Runtime Mode ──────────────────────────────────────────
# SIMULATOR = browser dev (no BrightSign hardware)
# BRIGHTSIGN = production player
VITE_RUNTIME_MODE=SIMULATOR

# ─── Hardware Profile ──────────────────────────────────────
# XT2145 = Touch Screen UI
# XC4055 = Three HDMI display deployment
# HD226  = Three independent cluster players
VITE_HARDWARE_PROFILE=XT2145

# ─── Deployment ────────────────────────────────────────────
# TOUCH_SCREEN | DISPLAY
VITE_DEPLOYMENT_TYPE=TOUCH_SCREEN

# HD226 cluster member: DEVICE_A | DEVICE_B | DEVICE_C
VITE_CLUSTER_MEMBER=DEVICE_A

# XC4055 display target: SCREEN_1 | SCREEN_2 | SCREEN_3
VITE_DISPLAY_TARGET=SCREEN_1

# ─── Simulator Device Overrides (optional) ─────────────────
VITE_SIM_SERIAL_NUMBER=
VITE_SIM_MODEL=
VITE_SIM_FIRMWARE_VERSION=
VITE_SIM_MAC_ADDRESS=
VITE_SIM_IP_ADDRESS=

# ─── Intervals (milliseconds) ──────────────────────────────
VITE_HEARTBEAT_INTERVAL_MS=60000
VITE_SYNC_INTERVAL_MS=300000
VITE_PAIRING_POLL_MS=30000
VITE_RUNTIME_VERSION=0.1.0
